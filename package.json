{
  "name": "lightweightproject",
  "version": "0.0.1",
  "description": "This is a lightweight NodeJS project for training, learning and practicing.",
  "author": "https://github.com/MarkDanilchenko",
  "private": true,
  "license": "UNLICENSED",
  "type": "commonjs",
  "engines": {
    "node": ">=24.0.0"
  },
  "imports": {
    "#server/*": [
      "./server/dist/src/*.js",
      "./server/dist/src/*/index.js",
      "./server/dist/src/*"
    ],
    "#shared/*": [
      "./shared/*.js",
      "./shared/*/index.js",
      "./shared/*"
    ]
  },
  "scripts": {
    "build:server": "cd server && npm run clear:server && nest build && tsc-alias",
    "clear:server": "rm -rf ./server/dist",
    "clear:node_modules": "rm -rf ./node_modules",
    "start:server": "cd server && nest start",
    "start:server:dev": "cd server && nest start --watch",
    "start:server:debug": "cd server && nest start --debug --watch",
    "start:server:prod": "cd server && node dist/src/main",
    "start:microservice:rmq": "cd server && ts-node -r tsconfig-paths/register src/microservice.rmq.ts",
    "start:microservice:rmq:dev": "cd server && nodemon --watch 'src/**/*.ts' --exec ts-node -r tsconfig-paths/register src/microservice.rmq.ts",
    "start:microservice:rmq:prod": "cd server && node dist/src/microservice.rmq.js",
    "typeorm": "ts-node -r tsconfig-paths/register ./node_modules/typeorm/cli.js",
    "typeorm:create": "npm run typeorm migration:create",
    "typeorm:run": "npm run typeorm migration:run -- -d ./server/src/configs/typeorm.configuration.ts",
    "typeorm:revert": "npm run typeorm migration:revert -- -d ./server/src/configs/typeorm.configuration.ts",
    "typeorm:generate": "npm run typeorm migration:generate -- -d ./server/src/configs/typeorm.configuration.ts",
    "typeorm:show": "npm run typeorm migration:show -- -d ./server/src/configs/typeorm.configuration.ts",
    "test:unit": "NODE_ENV=test jest --detectOpenHandles --bail --forceExit --passWithNoTests=false",
    "test:e2e": "NODE_ENV=test jest --detectOpenHandles --config server/tests/jest-e2e.json --bail --forceExit --passWithNoTests=false",
    "test:unit:cov": "NODE_ENV=test jest --coverage --bail --forceExit --passWithNoTests=false",
    "test:e2e:cov": "NODE_ENV=test jest --config server/tests/jest-e2e.json --coverage --bail --forceExit --passWithNoTests=false",
    "test:clear": "rm -rf ./server/coverage",
    "tsc": "tsc --noEmit",
    "lint:server": "eslint ./server/src/**/*.ts server/tests/**/*.ts ./server/migrations/**/*.ts",
    "format:server": "prettier --write ./server/src/**/*.ts  ./server/tests/**/*.ts ./server/migrations/**/*.ts && eslint ./server/src/**/*.ts ./server/tests/**/*.ts ./server/migrations/**/*.ts --fix",
    "postinstall": "patch-package"
  },
  "dependencies": {
    "@adminjs/express": "6.1.1",
    "@adminjs/nestjs": "7.0.0",
    "@adminjs/themes": "1.0.1",
    "@adminjs/typeorm": "5.0.1",
    "@anatine/zod-nestjs": "2.0.12",
    "@anatine/zod-openapi": "2.2.8",
    "@nestjs/common": "11.1.27",
    "@nestjs/config": "4.0.4",
    "@nestjs/core": "11.1.27",
    "@nestjs/event-emitter": "3.1.0",
    "@nestjs/jwt": "11.0.2",
    "@nestjs/microservices": "11.1.27",
    "@nestjs/passport": "11.0.5",
    "@nestjs/platform-express": "11.1.27",
    "@nestjs/schedule": "6.1.3",
    "@nestjs/swagger": "11.4.2",
    "@nestjs/typeorm": "11.0.3",
    "@node-saml/passport-saml": "5.1.0",
    "@types/nodemailer": "8.0.1",
    "@types/pg": "8.20.0",
    "adminjs": "7.8.17",
    "amqp-connection-manager": "5.0.0",
    "amqplib": "2.0.1",
    "axios": "1.18.1",
    "class-transformer": "0.5.1",
    "class-validator": "0.15.1",
    "cookie-parser": "1.4.7",
    "dotenv": "17.4.2",
    "ejs": "6.0.1",
    "express-formidable": "1.2.0",
    "express-session": "1.19.0",
    "ioredis": "5.11.1",
    "nest-winston": "1.10.2",
    "nodemailer": "9.0.3",
    "passport": "0.7.0",
    "passport-github2": "0.1.12",
    "passport-google-oauth20": "2.0.0",
    "passport-jwt": "4.0.1",
    "passport-local": "1.0.0",
    "passport-oauth2": "1.8.0",
    "passport-yandex": "0.0.5",
    "pg": "8.22.0",
    "reflect-metadata": "0.2.2",
    "rxjs": "7.8.2",
    "tslib": "2.8.1",
    "typeorm": "1.0.0",
    "uuid": "14.0.1",
    "winston": "3.19.0",
    "zod": "3.25.64"
  },
  "devDependencies": {
    "@eslint/eslintrc": "3.3.5",
    "@eslint/js": "10.0.1",
    "@faker-js/faker": "10.5.0",
    "@nestjs/cli": "11.0.23",
    "@nestjs/schematics": "11.1.0",
    "@nestjs/testing": "11.1.27",
    "@swc/cli": "0.6.0",
    "@swc/core": "1.15.43",
    "@types/amqplib": "0.10.8",
    "@types/cookie-parser": "1.4.10",
    "@types/ejs": "3.1.5",
    "@types/express": "5.0.6",
    "@types/ioredis": "5.0.0",
    "@types/jest": "30.0.0",
    "@types/node": "26.1.0",
    "@types/passport-github2": "1.2.9",
    "@types/passport-google-oauth20": "2.0.17",
    "@types/passport-jwt": "4.0.1",
    "@types/passport-local": "1.0.38",
    "@types/passport-saml": "1.1.7",
    "@types/supertest": "7.2.0",
    "eslint": "10.6.0",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-jest": "29.15.4",
    "eslint-plugin-prettier": "5.5.6",
    "globals": "17.7.0",
    "jest": "30.4.2",
    "nodemon": "3.1.14",
    "patch-package": "8.0.1",
    "prettier": "3.9.4",
    "source-map-support": "0.5.21",
    "supertest": "7.2.2",
    "ts-jest": "29.4.11",
    "ts-loader": "9.6.2",
    "ts-node": "10.9.2",
    "tsc-alias": "1.8.17",
    "tsconfig-paths": "4.2.0",
    "typescript": "6.0.3",
    "typescript-eslint": "8.62.1"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "./server",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": [
        "ts-jest",
        {
          "tsconfig": "./tsconfig.json"
        }
      ]
    },
    "transformIgnorePatterns": [
      "node_modules/(?!uuid|@faker-js/faker)"
    ],
    "moduleNameMapper": {
      "^#server/(.*)": "<rootDir>/src/$1",
      "^#shared/(.*)": "<rootDir>/../shared/$1"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s",
      "!**/*.(module|types|interfaces|dto|schema|guard).(t|j)s",
      "!**/src/configs/**",
      "!**/coverage/**",
      "!**/dist/**",
      "!**/insomnia/**",
      "!**/migrations/**",
      "!**/templates/**",
      "!**/tests/**"
    ],
    "coverageDirectory": "<rootDir>/coverage",
    "coverageReporters": [
      "html"
    ],
    "coverageThreshold": {
      "global": {
        "branches": 80,
        "functions": 80,
        "lines": 80,
        "statements": 80
      }
    },
    "testEnvironment": "node",
    "testTimeout": 5000
  },
  "browserslist": [
    "last 2 versions",
    "> 1%",
    "not ie < 10"
  ]
}
