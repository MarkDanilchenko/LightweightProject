{
  "compilerOptions": {
    "moduleResolution": "bundler",
    "module": "commonjs",
    "target": "esnext",
    "importHelpers": true,
    "allowJs": false,
    "removeComments": true,
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "strict": true,
    "forceConsistentCasingInFileNames": true,
    "declaration": false,
    "sourceMap": true,
    "incremental": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "noUnusedLocals": true,
    "ignoreDeprecations": "6.0",
    "baseUrl": ".",
    "paths": {
      "#server/*": ["./server/src/*"],
      "#shared/*": ["./shared/*"]
    },
    "types": ["jest", "node"]
  },
  "exclude": ["node_modules", "dist", "eslint.config.mjs"]
}
